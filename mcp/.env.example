# Runtime API key used by tunnel-client to authenticate to the OpenAI tunnel
# control plane.
#
# Create it at:
#   https://platform.openai.com/settings/organization/api-keys
#
# Give this key only the permissions needed to use the existing tunnel:
#   Tunnels: Read + Use
#
# Do not use an Admin API key here. Admin keys are only needed for tunnel CRUD
# operations such as creating/listing/updating/deleting tunnels.
CONTROL_PLANE_API_KEY="sk-..."

# OpenAI-hosted MCP tunnel id. Required.
#
# Create or inspect it at:
#   https://platform.openai.com/settings/organization/tunnels
#
# The id usually looks like:
#   tunnel_0123456789abcdef0123456789abcdef
#
CONTROL_PLANE_TUNNEL_ID="tunnel_..."

# Local tunnel-client profile name. Required. The script creates/updates this profile
# before starting the tunnel.
TUNNEL_PROFILE="shelter-test"

# Optional local admin UI address for tunnel-client /healthz, /readyz and /ui.
TUNNEL_HEALTH_LISTEN_ADDR="127.0.0.1:8080"

# Absolute path to the Shelter Steam/Desktop Godot project. Required.
# The directory must contain launch.sh and tools/dev-vertical-slice.sh.
SHELTER_STEAM_ROOT="/absolute/path/to/shelter/shelter/steam"

# Optional explicit roots for safe repo tools. Defaults are derived from
# SHELTER_STEAM_ROOT and this MCP checkout.
# SHELTER_MCP_REPO_ROOT="/absolute/path/to/shelter/shelter"
# SHELTER_MCP_SELF_ROOT="/absolute/path/to/shelter/mcp"

# Comma-separated filesystem roots delegated to @modelcontextprotocol/server-filesystem.
# Required if you want fs_* tools. A useful value is the parent directory that
# contains both this repo and the Shelter monorepo checkout.
SHELTER_MCP_FILESYSTEM_ROOTS="/absolute/path/to/shelter"

# Prefix added to proxied filesystem MCP tools, such as fs_read_text_file.
SHELTER_MCP_FILESYSTEM_PREFIX="fs_"

# Optional overrides.
# TUNNEL_CLIENT="/absolute/path/to/tunnel-client"
# SHELTER_MCP_BIN="/absolute/path/to/shelter-mcp"
# SHELTER_MCP_FILESYSTEM_COMMAND="/absolute/path/to/mcp-server-filesystem"
# SHELTER_MCP_FILESYSTEM=0
